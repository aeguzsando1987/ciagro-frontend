# Variables de entorno del frontend de CIAgro.
# Copiar a .env.local y completar con valores reales (no committear .env.local).

# URL base de la API del backend Django (incluye el prefijo /api/v1/).
# En desarrollo apunta al servicio local. En producción, al dominio de la API.
VITE_API_BASE_URL=http://localhost:8500/api/v1

# API key de MapTiler para los tiles vectoriales del visor de mapas (Paso 8b).
# Obtener una en https://cloud.maptiler.com (free tier 100k loads/mes).
# Cuando se migre a Protomaps self-hosted (GAP-INFRA-001), esta variable
# desaparece y se reemplaza por VITE_TILES_PMTILES_URL.
VITE_MAPTILER_KEY=your-maptiler-key-here
